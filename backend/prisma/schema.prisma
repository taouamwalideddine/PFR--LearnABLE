generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ENFANT
  PARENT
  EDUCATEUR
  ADMIN
}

enum Category {
  LANGAGE
  MATHEMATIQUES
  EMOTIONS
  COMPETENCES_SOCIALES
  VIE_QUOTIDIENNE
}

enum ActivityType {
  ASSOCIATION
  CHOIX_MULTIPLE
  SEQUENCES_LOGIQUES
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  role      Role      @default(PARENT)
  children  Child[]   @relation("UserChildren")
  posts     Post[]
  comments  Comment[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Child {
  id                 String    @id @default(cuid())
  name               String
  age                Int
  sensoryPreferences Json?     // e.g. { "lowStimulation": true, "soundEnabled": false }
  learningPace       String?
  difficultyLevel    Int       @default(1)
  parentId           String
  parent             User      @relation("UserChildren", fields: [parentId], references: [id])
  progress           Progress[]
  rewards            Reward[]
  lessons            Lesson[]  @relation("ChildLessons")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model Lesson {
  id          String    @id @default(cuid())
  title       String
  category    Category
  description String?
  difficulty  Int       @default(1)
  activities  Activity[]
  children    Child[]   @relation("ChildLessons")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Activity {
  id        String       @id @default(cuid())
  title     String
  type      ActivityType
  content   Json         // Specific data for the activity
  lessonId  String
  lesson    Lesson       @relation(fields: [lessonId], references: [id])
  progress  Progress[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model Progress {
  id          String    @id @default(cuid())
  childId     String
  child       Child     @relation(fields: [childId], references: [id])
  activityId  String
  activity    Activity  @relation(fields: [activityId], references: [id])
  completed   Boolean   @default(false)
  successRate Float     @default(0)
  timeSpent   Int       @default(0) // In seconds
  timestamp   DateTime  @default(now())
}

model Reward {
  id        String   @id @default(cuid())
  name      String
  type      String   // BADGE or STAR
  childId   String
  child     Child    @relation(fields: [childId], references: [id])
  reason    String?
  createdAt DateTime @default(now())
}

model Post {
  id        String    @id @default(cuid())
  title     String
  content   String
  category  String?
  authorId  String
  author    User      @relation(fields: [authorId], references: [id])
  comments  Comment[]
  likes     Int       @default(0)
  isReported Boolean  @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  postId    String
  post      Post     @relation(fields: [postId], references: [id])
  likes     Int      @default(0)
  createdAt DateTime @default(now())
}
